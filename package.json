{
  "name": "yelib-base",
  "version": "1.0.0",
  "description": "WhatsApp bot built on miuujs/baileys (yelib) ESM",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node --expose-gc index.js",
    "dev": "nodemon --expose-gc index.js",
    "start:cluster": "CLUSTER=1 node --expose-gc index.js",
    "dev:cluster": "CLUSTER=1 nodemon --expose-gc index.js",
    "postinstall": "npx playwright install --with-deps chromium && (apt-get install -y ffmpeg imagemagick iperf3 2>/dev/null || true)"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "baileys": "github:miuujs/baileys",
    "chalk": "^5.4.1",
    "cheerio": "^1.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-webpmux": "^3.2.1",
    "pino": "^9.6.0",
    "playwright": "^1.60.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "yt-search": "^2.13.1"
  },
  "license": "MIT"
}

# Phone number for pairing (include country code, no +)
PAIR_NO=6281234567890

# Pairing mode: true = use pairing code, false = use QR
PAIR_ISPAIR=true

# Session directory name
SESSION_DIR=session

# Bot mode: self = only owner can use, public = everyone can use
BOT_MODE=public

# Command prefix(es), comma-separated
PREFIX=.

# Owner number(s), comma-separated (country code without +)
OWNER_NUMBERS=6281234567890

# Owner display name
OWNER_NAME=Owner

# Sticker pack name
STICKER_PACK=yelib-base

# Sticker author name
STICKER_AUTHOR=yelib

# Timezone for logs
TZ=Asia/Jakarta
